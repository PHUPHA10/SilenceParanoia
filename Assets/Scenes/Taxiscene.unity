    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3.4
    delayAfter: 3
  - text: "\u0E1F\u0E49\u0E32: \u0E08\u0E30\u0E1E\u0E22\u0E32\u0E22\u0E32\u0E21\u0E19\u0E30\u0E04\u0E30\u0E25\u0E38\u0E07
      \u0E04\u0E07\u0E2D\u0E35\u0E01\u0E19\u0E32\u0E19\u0E01\u0E27\u0E48\u0E32\u0E08\u0E30\u0E40\u0E08\u0E2D"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3.4
    delayAfter: 1.4
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E19\u0E31\u0E48\u0E19\u0E2A\u0E34\u0E19\u0E30
      \u0E2E\u0E48\u0E32\u0E2E\u0E48\u0E32\u0E2E\u0E48\u0E32"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 2.9
    delayAfter: 4.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E2D\u0E35\u0E01\u0E19\u0E32\u0E19\u0E40\u0E25\u0E22\u0E01\u0E27\u0E48\u0E32\u0E08\u0E30\u0E16\u0E36\u0E07
      \u0E2D\u0E22\u0E32\u0E01\u0E14\u0E37\u0E48\u0E21\u0E19\u0E49\u0E33\u0E0B\u0E31\u0E01\u0E2B\u0E19\u0E48\u0E2D\u0E22\u0E21\u0E31\u0E49\u0E22"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3.5
    delayAfter: 2.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E25\u0E38\u0E07\u0E21\u0E35\u0E0B\u0E37\u0E49\u0E2D\u0E21\u0E32\u0E40\u0E1C\u0E37\u0E48\u0E2D\u0E1C\u0E39\u0E49\u0E42\u0E14\u0E22\u0E2A\u0E32\u0E23\u0E44\u0E27\u0E49
      \u0E40\u0E2B\u0E25\u0E37\u0E2D\u0E02\u0E27\u0E14\u0E2A\u0E38\u0E14\u0E17\u0E49\u0E32\u0E22\u0E1E\u0E2D\u0E14\u0E35"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 4.35
    delayAfter: 5
  refuseLines:
  - text: "\u0E1F\u0E49\u0E32: \u0E2B\u0E19\u0E39\u0E21\u0E35\u0E19\u0E49\u0E33\u0E2D\u0E22\u0E39\u0E48\u0E41\u0E25\u0E49\u0E27\u0E04\u0E48\u0E30
      \u0E02\u0E2D\u0E1A\u0E04\u0E38\u0E13\u0E17\u0E35\u0E48\u0E16\u0E32\u0E21\u0E19\u0E30\u0E04\u0E30"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 2.2
    delayAfter: 3
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E07\u0E31\u0E49\u0E19\u0E2B\u0E23\u0E2D
      \u0E44\u0E21\u0E48\u0E40\u0E1B\u0E47\u0E19\u0E44\u0E23\u0E40\u0E14\u0E35\u0E4B\u0E22\u0E27\u0E25\u0E38\u0E07\u0E40\u0E01\u0E47\u0E1A\u0E44\u0E27\u0E49\u0E01\u0E34\u0E19\u0E40\u0E2D\u0E07\u0E25\u0E30\u0E01\u0E31\u0E19"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3
    delayAfter: 4
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E41\u0E25\u0E49\u0E27\u0E15\u0E2D\u0E19\u0E19\u0E35\u0E49\u0E2B\u0E19\u0E39\u0E17\u0E33\u0E07\u0E32\u0E19\u0E40\u0E01\u0E35\u0E48\u0E22\u0E27\u0E01\u0E31\u0E1A\u0E2D\u0E30\u0E44\u0E23\u0E19\u0E30"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3
    delayAfter: 3.5
  - text: "\u0E1F\u0E49\u0E32: \u0E01\u0E47\u0E40\u0E1B\u0E47\u0E19\u0E1E\u0E19\u0E31\u0E01\u0E07\u0E32\u0E19\u0E1A\u0E23\u0E34\u0E29\u0E31\u0E17\u0E17\u0E31\u0E48\u0E27\u0E44\u0E1B\u0E2D\u0E48\u0E30\u0E04\u0E30"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3
    delayAfter: 2.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E41\u0E25\u0E49\u0E27\u0E17\u0E33\u0E44\u0E21\u0E27\u0E31\u0E19\u0E19\u0E35\u0E49\u0E40\u0E25\u0E34\u0E01\u0E14\u0E36\u0E01\u0E2B\u0E25\u0E30"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3
    delayAfter: 3.5
  - text: "\u0E1F\u0E49\u0E32: \u0E27\u0E31\u0E19\u0E19\u0E35\u0E49\u0E17\u0E33\u0E42\u0E2D\u0E17\u0E35\u0E40\u0E1E\u0E34\u0E48\u0E21\u0E04\u0E48\u0E30
      \u0E27\u0E31\u0E19\u0E2D\u0E37\u0E48\u0E19\u0E40\u0E25\u0E34\u0E01\u0E40\u0E22\u0E47\u0E19\u0E15\u0E32\u0E21\u0E1B\u0E01\u0E15\u0E34"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3
    delayAfter: 3
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E2D\u0E48\u0E2D
      \u0E14\u0E36\u0E01\u0E46\u0E01\u0E47\u0E23\u0E30\u0E27\u0E31\u0E07\u0E15\u0E31\u0E27\u0E14\u0E49\u0E27\u0E22\u0E19\u0E30\u0E2B\u0E19\u0E39"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 2.5
    delayAfter: 3
  - text: "\u0E1F\u0E49\u0E32: \u0E02\u0E2D\u0E1A\u0E04\u0E38\u0E13\u0E04\u0E48\u0E30"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 2
    delayAfter: 4
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E25\u0E38\u0E07\u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E44\u0E14\u0E49\u0E22\u0E34\u0E19\u0E40\u0E2A\u0E35\u0E22\u0E07\u0E41\u0E1B\u0E25\u0E01\u0E46\u0E21\u0E32\u0E08\u0E32\u0E01\u0E2B\u0E19\u0E49\u0E32\u0E23\u0E16"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 2
    delayAfter: 2.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E2B\u0E19\u0E39\u0E08\u0E30\u0E27\u0E48\u0E32\u0E2D\u0E30\u0E44\u0E23\u0E21\u0E31\u0E49\u0E22
      \u0E16\u0E49\u0E32\u0E25\u0E38\u0E07\u0E08\u0E30\u0E02\u0E2D\u0E08\u0E2D\u0E14\u0E02\u0E49\u0E32\u0E07\u0E17\u0E32\u0E07\u0E14\u0E39\u0E2B\u0E19\u0E48\u0E2D\u0E22"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 2
    delayAfter: 4
  noStopLines:
  - text: "\u0E1F\u0E49\u0E32: \u0E2B\u0E19\u0E39\u0E27\u0E48\u0E32\u0E25\u0E38\u0E07\u0E19\u0E48\u0E32\u0E08\u0E30\u0E2B\u0E39\u0E41\u0E27\u0E48\u0E27\u0E19\u0E30\u0E04\u0E30 "
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 2.5
    delayAfter: 3
  - text: "\u0E1F\u0E49\u0E32: \u0E40\u0E1E\u0E23\u0E32\u0E30\u0E2B\u0E19\u0E39\u0E44\u0E21\u0E48\u0E44\u0E14\u0E49\u0E22\u0E34\u0E19\u0E2D\u0E30\u0E44\u0E23\u0E40\u0E25\u0E22\u0E04\u0E48\u0E30 "
