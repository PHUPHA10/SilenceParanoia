    displayDuration: 2.5
    delayAfter: 4
  stopCarLines:
  - text: "\u0E1F\u0E49\u0E32:\u0E44\u0E14\u0E49\u0E04\u0E48\u0E30 \u0E22\u0E31\u0E07\u0E44\u0E07\u0E01\u0E47\u0E47\u0E16\u0E36\u0E07\u0E2B\u0E49\u0E2D\u0E07\u0E14\u0E36\u0E01\u0E2D\u0E22\u0E39\u0E48\u0E41\u0E25\u0E49\u0E27"
