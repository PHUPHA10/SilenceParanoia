    displayDuration: 2.5
    delayAfter: 3
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E16\u0E49\u0E32\u0E2D\u0E22\u0E48\u0E32\u0E07\u0E19\u0E31\u0E49\u0E19
      \u0E25\u0E38\u0E07\u0E23\u0E2D\u0E2A\u0E48\u0E07\u0E2B\u0E19\u0E39\u0E40\u0E2A\u0E23\u0E47\u0E08\u0E04\u0E48\u0E2D\u0E22\u0E40\u0E0A\u0E47\u0E04\u0E2D\u0E35\u0E01\u0E17\u0E35\u0E01\u0E47\u0E41\u0E25\u0E49\u0E27\u0E01\u0E31\u0E19"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 4
    delayAfter: 2.5
  - text: "\u0E1F\u0E49\u0E32: \u0E04\u0E48\u0E30 \u0E1E\u0E2D\u0E14\u0E35\u0E2B\u0E19\u0E39\u0E2D\u0E22\u0E32\u0E01\u0E23\u0E35\u0E1A\u0E01\u0E25\u0E31\u0E1A
