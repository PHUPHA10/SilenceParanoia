    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 4
    delayAfter: 2.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E44\u0E21\u0E48\u0E40\u0E1B\u0E47\u0E19\u0E44\u0E23\u0E08\u0E48\u0E30"
