    displayDuration: 3.5
    delayAfter: 1.9
  - text: "\u0E1F\u0E49\u0E32: \u0E2B\u0E19\u0E39\u0E44\u0E21\u0E48\u0E2D\u0E22\u0E32\u0E01\u0E08\u0E30\u0E15\u0E49\u0E2D\u0E07\u0E19\u0E31\u0E48\u0E07\u0E2A\u0E2D\u0E19\u0E19\u0E31\u0E48\u0E07\u0E23\u0E30\u0E41\u0E27\u0E07\u0E2D\u0E35\u0E01"
