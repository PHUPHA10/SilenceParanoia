    displayDuration: 3.5
    delayAfter: 3.21
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E25\u0E38\u0E07\u0E27\u0E48\u0E32\u0E04\u0E48\u0E2D\u0E22\u0E46\u0E40\u0E25\u0E37\u0E2D\u0E01\u0E41\u0E2B\u0E25\u0E30\u0E14\u0E35\u0E41\u0E25\u0E49\u0E27
