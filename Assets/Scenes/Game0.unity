    delayAfter: 3.35
  - text: "\u0E1F\u0E49\u0E32: \u0E15\u0E2D\u0E19\u0E19\u0E35\u0E49\u0E02\u0E2D\u0E41\u0E04\u0E48\u0E40\u0E1B\u0E47\u0E19\u0E04\u0E19\u0E14\u0E35
