    delayAfter: 2
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E02\u0E22\u0E31\u0E19\u0E17\u0E33\u0E07\u0E32\u0E19
