    displayDuration: 3.5
    delayAfter: 2.4
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E27\u0E48\u0E32\u0E41\u0E15\u0E48\u0E2B\u0E19\u0E39\u0E21\u0E35\u0E2A\u0E40\u0E1B\u0E04\u0E1C\u0E39\u0E49\u0E0A\u0E32\u0E22\u0E17\u0E35\u0E48\u0E0A\u0E2D\u0E1A\u0E21\u0E31\u0E49\u0E22"
