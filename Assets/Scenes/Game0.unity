  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fb1218c229a9df447ab32978fe6f93f8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 913293381}
  dialoguePanel: {fileID: 415394277}
  delayBeforeStart: 3.7
  delayBeforeChoice: 3
  lines:
  - text: "\u0E1F\u0E49\u0E32: \u0E44\u0E1B\u0E15\u0E32\u0E21\u0E41\u0E21\u0E1E\u0E40\u0E25\u0E22\u0E19\u0E30\u0E04\u0E30\u0E04\u0E38\u0E13\u0E25\u0E38\u0E07"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3.5
    delayAfter: 1.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E44\u0E14\u0E49\u0E04\u0E23\u0E31\u0E1A\u0E1C\u0E21"
    textColor: {r: 0.9528302, g: 0.6503752, b: 0.12135102, a: 1}
    displayDuration: 2.8
    delayAfter: 10
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E27\u0E31\u0E19\u0E19\u0E35\u0E49\u0E40\u0E25\u0E34\u0E01\u0E07\u0E32\u0E19\u0E14\u0E36\u0E01\u0E2B\u0E23\u0E2D\u0E2B\u0E19\u0E39"
    textColor: {r: 0.9528302, g: 0.6503752, b: 0.12135102, a: 1}
    displayDuration: 3.5
    delayAfter: 2.1
  - text: "\u0E1F\u0E49\u0E32: \u0E43\u0E0A\u0E48\u0E04\u0E48\u0E30 \u0E1E\u0E2D\u0E14\u0E35\u0E21\u0E35\u0E17\u0E33\u0E42\u0E2D\u0E17\u0E35\u0E40\u0E1E\u0E34\u0E48\u0E21\u0E19\u0E34\u0E14\u0E2B\u0E19\u0E48\u0E2D\u0E22\u0E04\u0E48\u0E30"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3.5
    delayAfter: 2
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E41\u0E25\u0E49\u0E27\u0E17\u0E33\u0E44\u0E21\u0E44\u0E21\u0E48\u0E43\u0E2B\u0E49\u0E41\u0E1F\u0E19\u0E21\u0E32\u0E23\u0E31\u0E1A\u0E2B\u0E25\u0E30"
    textColor: {r: 0.95294124, g: 0.6509804, b: 0.121568635, a: 1}
    displayDuration: 3.5
    delayAfter: 2.05
  - text: "\u0E1F\u0E49\u0E32: \u0E1E\u0E2D\u0E14\u0E35\u0E2B\u0E19\u0E39\u0E40\u0E1E\u0E34\u0E48\u0E07\u0E40\u0E25\u0E34\u0E01\u0E01\u0E31\u0E1A\u0E41\u0E1F\u0E19\u0E2D\u0E30\u0E04\u0E48\u0E30 "
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3.5
    delayAfter: 1.5
  - text: "\u0E1F\u0E49\u0E32: \u0E08\u0E1A\u0E44\u0E21\u0E48\u0E14\u0E35\u0E14\u0E49\u0E27\u0E22
      \u0E40\u0E25\u0E22\u0E44\u0E21\u0E48\u0E2D\u0E22\u0E32\u0E01\u0E27\u0E38\u0E48\u0E19\u0E27\u0E32\u0E22\u0E01\u0E31\u0E19\u0E2D\u0E35\u0E01\u0E04\u0E48\u0E30"
    textColor: {r: 1, g: 1, b: 1, a: 1}
    displayDuration: 3.5
    delayAfter: 3.2
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E2B\u0E32\u0E43\u0E2B\u0E21\u0E48\u0E40\u0E25\u0E22\u0E2B\u0E19\u0E39
