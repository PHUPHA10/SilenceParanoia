    displayDuration: 3
    delayAfter: 2.5
  - text: "\u0E25\u0E38\u0E07\u0E41\u0E17\u0E47\u0E01\u0E0B\u0E35\u0E48: \u0E41\u0E25\u0E49\u0E27\u0E17\u0E33\u0E44\u0E21\u0E27\u0E31\u0E19\u0E19\u0E35\u0E49\u0E40\u0E25\u0E34\u0E01\u0E14\u0E36\u0E01\u0E40\u0E19\u0E35\u0E48\u0E22"
